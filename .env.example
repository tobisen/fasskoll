AUTH_USERNAME="Jenny&Tobbe"
AUTH_PASSWORD_HASH=220f24a42a45b1490ee59ada37b9f6232dccc3cd28b1d6ba43e16c6a561935f2
AUTH_PASSWORD_SALT=fasskoll-v1-salt
AUTH_SESSION_SECRET=change-this-to-a-long-random-secret

# Optional: override multiple users at once (username -> PBKDF2-SHA256 hash).
# If AUTH_USERS_JSON is set, AUTH_USERNAME/AUTH_PASSWORD_HASH are ignored.
# Example includes Jenny&Tobbe and admin (NeoSally2Fasskoll).
AUTH_USERS_JSON='{"Jenny&Tobbe":"220f24a42a45b1490ee59ada37b9f6232dccc3cd28b1d6ba43e16c6a561935f2","admin":"cf44996d6a28ef5dfec3b4a3a9076a4e385400ce8688ff93f3b887f9c4ea26b0"}'

# Service kill switch (set to true/1 to disable stock/search API quickly)
FASSKOLL_KILL_SWITCH=false
FASSKOLL_KILL_SWITCH_MESSAGE="Tjänsten är tillfälligt avstängd. Försök igen senare."

# Rate limits
FASS_GUEST_CONTENT_RATE_LIMIT_PER_MIN=24
FASS_GUEST_CONTENT_BLOCK_MINUTES=3
FASS_AUTH_CONTENT_RATE_LIMIT_PER_MIN=120
FASS_AUTH_CONTENT_BLOCK_MINUTES=2
FASS_GUEST_STOCK_RATE_LIMIT_PER_MIN=8
FASS_GUEST_STOCK_BLOCK_MINUTES=5
FASS_AUTH_STOCK_RATE_LIMIT_PER_MIN=40
FASS_AUTH_STOCK_BLOCK_MINUTES=2

# Optional persistent metrics store on Vercel/Upstash KV (recommended in production).
# If not set, metrics fall back to local /tmp storage (best-effort only).
KV_REST_API_URL=
KV_REST_API_TOKEN=
METRICS_KV_KEY=fasskoll:metrics:v1
