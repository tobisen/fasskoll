AUTH_USERS_JSON='{"Jenny&Tobbe":"220f24a42a45b1490ee59ada37b9f6232dccc3cd28b1d6ba43e16c6a561935f2","admin":"cf44996d6a28ef5dfec3b4a3a9076a4e385400ce8688ff93f3b887f9c4ea26b0"}'

# Service kill switch (set to true/1 to disable stock/search API quickly)
