{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/api/content",
      "destination": "/api/content"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
